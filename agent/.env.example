# ─── Lumora AI Agent configuration ───────────────────────────
# Copy this file to ".env" and paste YOUR OWN Gemini API key below.
# The .env file is git-ignored, so the key never leaves your machine
# and never reaches the frontend or the repository.
#
# Get a key at: https://aistudio.google.com/apikey

# Port the agent listens on (Vite proxies /agent to this in dev)
AGENT_PORT=4000

# Provider: "gemini" | "openai" | "mock"
# Gemini is the default for this project.
AI_PROVIDER=gemini

# ── Gemini (Google AI Studio) ──
GEMINI_API_KEY=PASTE_YOUR_GEMINI_KEY_HERE
# Current model as of 2026. Gemini 1.x, 2.0 and 2.5 are retired or closed to
# new users; the Gemini 3 series is current. Use "gemini-flash-latest" to
# always get the newest flash model automatically.
GEMINI_MODEL=gemini-3.5-flash

# ── OpenAI (only if AI_PROVIDER=openai) ──
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
